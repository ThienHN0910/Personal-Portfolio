{
  "name": "@portfolio/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vercel dev --local --listen 3000",
    "typecheck": "tsc -p tsconfig.api.json --noEmit",
