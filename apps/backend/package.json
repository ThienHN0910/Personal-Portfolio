    "jsonwebtoken": "^9.0.0",
    "cloudinary": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@vercel/node": "^3.0.0"
  }
}
