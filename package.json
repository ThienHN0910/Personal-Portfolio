{
  "name": "personal-portfolio",
  "version": "1.0.0",
  "description": "Monorepo for personal portfolio frontend and backend",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "npm run dev -w @portfolio/frontend",
    "dev:backend": "npm run dev -w @portfolio/backend",
    "build": "npm run build:frontend",
    "build:frontend": "npm run build -w @portfolio/frontend",
    "typecheck:backend": "npm run typecheck -w @portfolio/backend",
    "preview": "npm run preview -w @portfolio/frontend",
    "deploy:backend": "vercel deploy --prod --yes --scope thiens-projects-2041d8cd --cwd apps/backend",
    "deploy:frontend": "vercel deploy --prod --yes --scope thiens-projects-2041d8cd --cwd apps/frontend"
  },
  "devDependencies": {}
}
