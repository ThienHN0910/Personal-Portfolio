{
  "name": "personal-portfolio-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "npm --prefix fe run dev",
    "dev:be": "npm --prefix backend run dev",
    "build": "npm run build:fe && npm run build:be",
    "build:fe": "npm --prefix fe run build",
    "build:be": "npm --prefix backend run build",
    "typecheck": "npm run typecheck:fe && npm run typecheck:be",
    "typecheck:fe": "npm --prefix fe run typecheck",
    "typecheck:be": "npm --prefix backend run typecheck",
    "preview:fe": "npm --prefix fe run preview",
    "start:be": "npm --prefix backend run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
